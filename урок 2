# 4) Формирование шапки для процессуального документа
def build_court_header(answerant: Dict[str, str], case_number: str) -> str:
    """
    Формирует шапку документа по данным ответчика и номеру дела.

    Args:
        answerant: словарь с данными ответчика:
            {
                "full_name": "...",
                "address": "...",
                "passport": "..."
            }
        case_number: номер дела (строка)

    Returns:
        Строка-шапка для процессуального документа.
    """
    case_info = _saks_data.get(case_number)
    if not case_info:
        raise ValueError(f"Не найден суд для номера дела: {case_number}")

    court_name = case_info["court_name"]
    court_address = case_info["address"]

    claimant = claimant_example()

    header = (
        f"{court_name}\n"
        f"Адрес: {court_address}\n"
        f"Истец: {claimant['full_name']}\n"
        f"Адрес истца: {claimant['address']}\n"
        f"Паспорт истца: {claimant['passport']}\n"
        f"Ответчик: {answerant.get('full_name')}\n"
        f"Адрес ответчика: {answerant.get('address')}\n"
        f"Паспорт ответчика: {answerant.get('passport')}\n"
        f"Номер дела: {case_number}"
    )
    return header

# 5) Генерация шапок для списка ответчиков
def generate_headers_for_answerants(answerants: List[Dict[str, str]], case_map: Dict[int, str]) -> None:
    """
    Для каждого ответчика из списка генерирует шапку и выводит её в консоль.

    Args:
        answerants: список словарей данных ответчиков
            каждый словарь должен содержать ключи: full_name, address, passport
        case_map: карта индекса ответчика -> номер дела, например {0: "A40-123456/2023"}
    """
    for idx, ans in enumerate(answerants):
        case_no = case_map.get(idx)
        if not case_no:
            print(f"[Ошибка] Нет номера дела для ответчика под индексом {idx}")
            continue
        header = build_court_header(ans, case_no)
        print(header)
        print("-" * 40)

