from math import factorial as _factorial
from typing import List, Dict

# 1) Математические функции

def factorial(n: int) -> int:
    """
    Вычисляет факториал числа n (n!).
    Принимает неотрицательное целое число n, возвращает факториал.
    """
    if not isinstance(n, int) or n < 0:
        raise ValueError("n должен быть неотрицательным целым числом")
    return _factorial(n)

def max_of_three(t: tuple) -> int:
    """
    Находит наибольшее число среди трёх значений.
    Принимает кортеж из трёх чисел (a, b, c), возвращает максимум.
    """
    if not isinstance(t, tuple) or len(t) != 3:
        raise ValueError("t должен быть кортежем из трёх элементов")
    a, b, c = t
    return max(a, b, c)

def area_of_right_triangle(a: float, b: float) -> float:
    """
    Вычисляет площадь прямоугольного треугольника по катетам a и b.
    P = 0.5 * a * b
    """
    if a < 0 or b <0:
        raise ValueError("Катеты должны быть неотрицательными")
    return 0.5 * a * b

